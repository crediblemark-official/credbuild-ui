{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Credbuild UI Companion Library",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "moduleResolution": "node",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "target": "ES2020",
    "baseUrl": ".",
    "paths": {
      "@/components/credbuild/*": ["./src/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/lib/media/utils": ["./src/lib/media-utils.ts"],
      "@/components/ui/Portal": ["./src/components/Portal.tsx"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
